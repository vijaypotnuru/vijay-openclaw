@echo off
:: ============================================================
:: OpenClaw Post-Setup - Run AFTER restart
:: Double-click this file after WSL + Ubuntu is installed
:: ============================================================

echo ============================================================
echo   OpenClaw Post-Setup (run after restart)
echo ============================================================
echo.
echo This runs inside WSL Ubuntu to complete OpenClaw setup.
echo.

powershell -ExecutionPolicy Bypass -NoProfile -Command ^
  "='';" ^
  "=[System.Convert]::FromBase64String();" ^
  "=[System.Text.Encoding]::UTF8.GetString();" ^
  "=\":TEMP\openclaw-postsetup.sh\";" ^
  "[IO.File]::WriteAllText(,);" ^
  "wsl -d Ubuntu -- bash "

echo.
pause
